// ============================================================
//  localStorage-এ attempts সংরক্ষণ
// ============================================================
function getAttempts() {
  try {
    const data = localStorage.getItem('testBazarAttempts');
    return data ? JSON.parse(data) : {};
  } catch { return {}; }
}

function saveAttempts(attempts) {
  localStorage.setItem('testBazarAttempts', JSON.stringify(attempts));
}

function getAttemptCount(username, setId) {
  const attempts = getAttempts();
  const key = username + '|' + setId;
  return attempts[key] || 0;
}

function incrementAttempt(username, setId) {
  const attempts = getAttempts();
  const key = username + '|' + setId;
  attempts[key] = (attempts[key] || 0) + 1;
  saveAttempts(attempts);
  return attempts[key];
}

